# RevRoute MCP — environment variables

# Required: API key for revroute.ru workspace. Generate one in the workspace settings.
REVROUTE_API_KEY=

# Optional: override the API base URL.
# Production: https://app.revroute.ru/api
# Staging:    separate environment (typically WAF-restricted; ask the revroute team for the host)
REVROUTE_API_BASE_URL=https://app.revroute.ru/api

# Optional: enable the partner-program tool set (programs, partners, commissions, bounties, payouts).
REVROUTE_ENABLE_PARTNERS=0

# Optional: emit verbose request/response traces to stderr (headers masked, body capped at 2 KB).
REVROUTE_DEBUG=0

# Optional (HTTP transport only): override host/port.
REVROUTE_HTTP_HOST=127.0.0.1
REVROUTE_HTTP_PORT=8787

# Optional (HTTP transport only): comma-separated list of allowed CORS origins.
# Default during dev is "*"; tighten for production.
REVROUTE_CORS_ORIGIN=*
