{
  "name": "revroute-mcp",
  "version": "0.2.1",
  "description": "MCP server for revroute.ru — manage short links and custom domains, read click and conversion analytics, run affiliate and referral programs (partners, commissions, bounties, payouts), and trigger conversion tracking from any LLM that speaks Model Context Protocol (Claude, Cursor, Claude Code, and more).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "revroute-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "examples"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test",
    "dxt:pack": "node scripts/pack-dxt.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "revroute",
    "short-links",
    "url-shortener",
    "link-shortener",
    "link-management",
    "link-analytics",
    "click-tracking",
    "conversion-tracking",
    "qr-code",
    "affiliate",
    "affiliate-marketing",
    "affiliate-program",
    "referral",
    "referral-program",
    "partner-program",
    "partners",
    "commissions",
    "payouts",
    "bounties",
    "anthropic",
    "claude",
    "cursor",
    "ai-agent"
  ],
  "author": "RevRoute",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IndiFox/revroute-mcp.git"
  },
  "homepage": "https://github.com/IndiFox/revroute-mcp#readme",
  "bugs": {
    "url": "https://github.com/IndiFox/revroute-mcp/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "commander": "^14.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^20.14.10",
    "msw": "^2.6.4",
    "tsup": "^8.3.5",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.6"
  }
}
